{
  "name": "vellum-db",
  "version": "0.4.0",
  "description": "Structured storage for Vellum agents: TableDefinition tables, query/aggregate via JSON, named views.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.12.0"
  },
  "peerDependencies": {
    "@vellumai/plugin-api": "^0.8.0"
  },
  "vellum": {},
  "dependencies": {
    "@truto/sqlite-builder": "^2.0.1",
    "ajv": "^8.20.0",
    "chart.js": "^4.5.1",
    "nanoid": "^6.0.0",
    "preact": "^10.29.7",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "scripts": {
    "dev:app": "bun scripts/dev-tables-app.ts",
    "openapi": "bun scripts/generate-openapi.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p apps/tables",
    "check": "bun run lint && bun test",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^9.1.0",
    "@biomejs/biome": "^2.5.5",
    "@types/bun": "^1.3.14",
    "@types/xlsx": "^0.0.36",
    "@vellumai/plugin-api": "^0.8.0",
    "typescript": "^5.9.3"
  }
}

          "default": 0
        }
      },
      {
        "name": "Category",
        "slug": "category_id",
        "data": {
          "type": "ref",
          "table": "category",
          "column": "category_id",
          "onDelete": "restrict"
        }
      },
      {
        "name": "Description",
        "slug": "description",
        "data": { "type": "str", "minLen": 1 }

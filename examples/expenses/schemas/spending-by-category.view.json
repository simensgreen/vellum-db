{
  "slug": "spending_by_category",
  "name": "Spending by category",
  "kind": "aggregate",
  "scope": "expenses",
  "description": "Total amount and count per category for a date range",
  "definition": {
    "table": "expenses",
    "joins": [
      {
        "ref": "category_id",
        "type": "inner",
        "select": { "name": "category_name" }
      }
    ],
    "metrics": [
      { "fn": "sum", "column": "amount", "as": "total_amount" },
      { "fn": "count", "as": "expense_count" }
    ],
    "group_by": ["category_name"],
    "filter": {
      "and": [
        { "spent_at": { "gte": "$from" } },
        { "spent_at": { "lte": "$to" } }
      ]
    },
    "order": [{ "column": "total_amount", "direction": "desc" }]
  }
}

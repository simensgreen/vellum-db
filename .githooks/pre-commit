#!/bin/sh
set -e

root="$(git rev-parse --show-toplevel)"
cd "$root"

staged="$(git diff --cached --name-only)"

if printf '%s\n' "$staged" | grep -qE '\.(ts|tsx|js|jsx|css|json)$'; then
  bunx biome check --staged --no-errors-on-unmatched
fi

if printf '%s\n' "$staged" | grep -qE '^(src/api/|src/openapi/|routes/|scripts/generate-openapi\.ts)'; then
  bun run openapi
  git add openapi.json
fi
